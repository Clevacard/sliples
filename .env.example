# Sliples Environment Variables
# Copy to .env and customize for your environment

# Database
DATABASE_URL=postgresql://sliples:sliples_dev@localhost:5432/sliples

# Redis
REDIS_URL=redis://localhost:6379/0

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=sliples-screenshots
S3_ACCESS_KEY=sliples
S3_SECRET_KEY=sliples_dev

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=sliples@example.com

# Security
SECRET_KEY=change-this-in-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Playwright Browsers
BROWSER_CHROME_URL=ws://localhost:3001
BROWSER_FIREFOX_URL=ws://localhost:3002

# Data Retention (days)
RETENTION_DAYS=365
